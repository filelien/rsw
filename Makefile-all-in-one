.PHONY: up down build logs ps clean reset

# Start all services with all-in-one Dockerfile
up:
	cp -n .env.example .env 2>/dev/null || true
	docker compose -f docker-compose-all-in-one.yml up -d --build

# Start without rebuild
start:
	docker compose -f docker-compose-all-in-one.yml up -d

# Stop all
down:
	docker compose -f docker-compose-all-in-one.yml down

# Build all images
build:
	docker compose -f docker-compose-all-in-one.yml build

# View logs
logs:
	docker compose -f docker-compose-all-in-one.yml logs -f

logs-raxus:
	docker compose -f docker-compose-all-in-one.yml logs -f raxus

logs-infra:
	docker compose -f docker-compose-all-in-one.yml logs -f mysql redis

# Status
ps:
	docker compose -f docker-compose-all-in-one.yml ps

# Clean everything (data included)
clean:
	docker compose -f docker-compose-all-in-one.yml down -v --remove-orphans
	docker system prune -f

# Reset DB only
reset-db:
	docker compose -f docker-compose-all-in-one.yml stop mysql
	docker compose -f docker-compose-all-in-one.yml rm -f mysql
	docker volume rm raxus_mysql_data 2>/dev/null || true
	docker compose -f docker-compose-all-in-one.yml up -d mysql

# Shell into RAXUS container
shell-raxus:
	docker compose -f docker-compose-all-in-one.yml exec raxus bash

# Send test alert (Prometheus format)
test-alert:
	curl -X POST http://localhost:8000/api/v1/alerts/ingest/prometheus \
	  -H "Content-Type: application/json" \
	  -d '{"version":"4","status":"firing","alerts":[{"status":"firing","labels":{"alertname":"TestAlert","severity":"critical","instance":"server-01","job":"node"},"annotations":{"summary":"Test critical alert from RAXUS","description":"This is a test"}}]}'

# Test webhook
test-webhook:
	curl -X POST http://localhost:8000/api/v1/alerts/ingest/webhook \
	  -H "Content-Type: application/json" \
	  -d '{"alerts":[{"name":"HighCPU","severity":"major","instance":"web-01","summary":"CPU above 90%","value":92.5,"threshold":90}]}'

# API docs
docs:
	@echo "RAXUS UI: http://localhost:3000"
	@echo "Gateway API docs: http://localhost:8000/docs"
	@echo "Grafana: http://localhost:3001"
	@echo "VictoriaMetrics: http://localhost:8428"
	@echo "Vault: http://localhost:8200"

# Health check all services
health:
	@echo "🔍 Checking RAXUS All-in-One health..."
	@curl -s http://localhost:3000 > /dev/null && echo "✅ Frontend: OK" || echo "❌ Frontend: DOWN"
	@curl -s http://localhost:8000/health > /dev/null && echo "✅ Gateway: OK" || echo "❌ Gateway: DOWN"
	@curl -s http://localhost:8001/health > /dev/null && echo "✅ Alertmanager: OK" || echo "❌ Alertmanager: DOWN"
	@curl -s http://localhost:8002/health > /dev/null && echo "✅ Inventory: OK" || echo "❌ Inventory: DOWN"
	@curl -s http://localhost:8003/health > /dev/null && echo "✅ Notifier: OK" || echo "❌ Notifier: DOWN"
	@curl -s http://localhost:8004/health > /dev/null && echo "✅ TaskManager: OK" || echo "❌ TaskManager: DOWN"
	@curl -s http://localhost:8005/health > /dev/null && echo "✅ SLO Engine: OK" || echo "❌ SLO Engine: DOWN"
	@curl -s http://localhost:8006/health > /dev/null && echo "✅ Rules Engine: OK" || echo "❌ Rules Engine: DOWN"

# Quick start (one command)
quick-start:
	@echo "🚀 Starting RAXUS All-in-One..."
	make up
	@echo "⏳ Waiting for services to start..."
	sleep 30
	make health

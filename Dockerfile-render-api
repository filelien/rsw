# ─── RAXUS API FOR RENDER ───────────────────────────────────────────────
# Dockerfile optimisé pour Render avec tous les services Python combinés

FROM python:3.12-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY services/gateway/requirements.txt ./requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Install additional dependencies for all services
RUN pip install --no-cache-dir celery email-validator

# Copy all services
COPY services/ ./services/

# Copy the combined API server
COPY combined_api.py .

# Environment defaults
ENV ENVIRONMENT=production
ENV PORT=10000

EXPOSE 10000

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:10000/health || exit 1

CMD ["python", "combined_api.py"]

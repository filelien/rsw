# ─── RAXUS ENVIRONMENT CONFIGURATION ────────────────────────────
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
SECRET_KEY=change-this-to-a-random-64-char-string

# MySQL
MYSQL_ROOT_PASSWORD=raxus_root_secure
MYSQL_PASSWORD=raxus_pass_secure

# Redis
REDIS_PASSWORD=raxus_redis_secure

# Vault
VAULT_TOKEN=raxus-vault-token

# Grafana
GRAFANA_PASSWORD=admin_secure

# SMTP (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password

# Optional: Slack notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
